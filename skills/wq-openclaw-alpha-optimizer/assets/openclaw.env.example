# WorldQuant credentials
export WQ_USERNAME="your_email@example.com"
export WQ_PASSWORD="your_password"

# Optional: LLM env fallback when not using --llm-config
export LLM_API_KEY="your_llm_api_key"
export LLM_MODEL="gpt-4.1-mini"
export LLM_BASE_URL="https://your-openai-compatible-endpoint/v1"
export LLM_TEMPERATURE="0.2"
export LLM_MAX_TOKENS="2400"
