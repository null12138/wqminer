# Supabase Postgres direct connection string
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Brain API credentials (remote submitter only) — email to request access after starring
WQB_USERNAME=your_email@example.com
WQB_PASSWORD=your_password
BRAIN_API_BASE_URL=

# Worker tuning
WORKER_ID=remote-submitter-01
CONCURRENCY=56
FETCH_SIZE=100
POLL_INTERVAL_MS=2000
SIMULATION_WAIT_SECS=900
STATUS_POLL_SECS=5
AUTO_SUBMIT=false
DB_POOL_MAX=20
