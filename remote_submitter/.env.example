# Supabase Postgres direct connection string
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# WorldQuant Brain credentials (remote submitter only)
WQB_USERNAME=your_email@example.com
WQB_PASSWORD=your_password
WQB_BASE_URL=https://api.worldquantbrain.com

# Worker tuning
WORKER_ID=remote-submitter-01
CONCURRENCY=56
FETCH_SIZE=100
POLL_INTERVAL_MS=2000
SIMULATION_WAIT_SECS=900
STATUS_POLL_SECS=5
AUTO_SUBMIT=false
DB_POOL_MAX=20
